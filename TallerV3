#include <stdio.h>
#include <string.h>
// Ariana Llumiquinga ING, SOFWARE 2DO SEMESTRE UDLA
int main(){

    char ID [10];
    char name [30];
    int stock=0;
    int opc=0;
    int aux_cantidad;
    float precio=0.0;
    float acumulado_totales=0.0;
    float subtotal=0.0;
    float porc_desc=0.0;
    float valor_descuento=0.0;
    float total_final_ventas=0.0;
    do {
        printf("\n--------Menu de Ventas--------");
        printf("\n-----Seleccione una opcion-----");
        printf("\n1....... Registro del producto");
        printf("\n2.Vender unidades del producto");
        printf("\n3..... Reabastecer el producto");
        printf("\n4.Consultar informacion del producto");
        printf("\n5..........Ganancias obtenidas");
        printf("\n6........................Salir");
        printf("\nIngrese su opcion: ");

        if (scanf("%d",&opc)!=1||opc<1||opc>6) {
            printf("\nIngrese un numero valido");
            while (getchar()!='\n');
            continue;
        }
        
        switch (opc)
        {
            case 1:

                printf("\nIngrese el ID del producto: ");
                scanf(" %s", ID);
                printf("Ingrese el nombre de producto: ");
                scanf(" %[^\n]s", name);
                printf("Ingrese el stock inical: ");
                scanf("%d", &stock);
                printf("Ingrese precio unitario del producto: ");
                scanf("%f", &precio);
                printf(">>Su producto ha sido registrado<<\n");
                break;
            case 2:
                if (stock<=0){
                    printf("\n No hay stock disponible para vender");
                }else{
                    printf("Cuantas unidades del producto desea vender: ");
                    
                    if (scanf("%d",&aux_cantidad)!=1||aux_cantidad<0||aux_cantidad>stock){
                        printf("Error: Solo hay %d unidades disponibes",stock);
                        printf("Ingrese numeros positivos");
                        while (getchar()!='\n');
                        aux_cantidad=0;
                        
                    }else {
                        subtotal=aux_cantidad*precio;
                        valor_descuento=0;
                        
                        if (aux_cantidad >= 12) {
                            do {
                                printf("Venta al por mayor. Ingrese descuento (0 a 25%%): ");
                                
                                if (scanf("%f", &porc_desc) != 1) { 
                                    printf("[!] Error: Ingrese un numero decimal.\n");
                                    while (getchar() != '\n'); 
                                    porc_desc = -1; 
                                    continue;
                                }

                                // 2. Luego validamos el valor
                                if (porc_desc < 0 || porc_desc > 25) {
                                    printf("[!] El descuento debe estar entre 0 y 25.\n");
                                }
                            } while (porc_desc < 0 || porc_desc > 25);

                            valor_descuento = subtotal * (porc_desc / 100.0);
                        }

                        total_final_ventas = subtotal - valor_descuento;
                        stock -= aux_cantidad;
                        acumulado_totales+= total_final_ventas;

                        printf("\n--- Ticket de Venta ---");
                        printf("\nSubtotal:\t$%.2f", subtotal);
                        printf("\nDesc. (%g%%):\t-$%.2f", porc_desc, valor_descuento);
                        printf("\nTotal Pago:\t$%.2f", total_final_ventas);
                        printf("\n>> Venta Exitosa <<\n");
                    }  
                }
                break;
            case 3:
                printf("Cantidad de productoa a agregar: ");
                if(scanf("%d",&aux_cantidad)!=1||aux_cantidad<0){
                    printf("Error: ingrese un numero positivo");
                }else{
                    stock+= aux_cantidad;
                    printf("Su stock a sido actualizado %d unidades",stock);
                }
                break;
            case 4:
                printf("\n--- INFO DEL PRODUCTO ---");
                printf("\nID:\t\t%s", ID);
                printf("\nNombre:\t\t%s", name);
                printf("\nStock:\t\t%d unidades", stock);
                printf("\nPrecio:\t\t$%.2f\n", precio);
                break;
            case 5:
                printf("\nGANANCIAS TOTALES: $%.2f", total_final_ventas);
                printf("\n============================\n");
                break;
            case 6:
                printf("Saliendo del programa..........");
                break;
            default:
                printf("\n[!] Opcion no valida.\n");
                break;
        }
    } while (opc!=6);
    return 0;
}
