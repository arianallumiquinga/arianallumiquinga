#include<stdio.h>
#include<string.h>// strlen 
int ingresarNombre(char nom[5][20], int n);
void leerCadena(char cadena[],int n);

int main(int argc,char*argv[]){

  char nombres[5][20];
  int cont =0, n=0;

  printf("Cuantos nombres deaea ingrear?");
  scanf("%d",&n);

  for (int i = 0; i <0 ; i++) {
      cont= ingresarNombre(nombres,cont);
  }
  
  for (int i = 0, i < cont ; i++){
        printf("%s\n",nombres[i]);

  }
  return 0;
}
int ingresarNombre(char nom[5][20], int n){
  printf("Ingresar el nombre de la persona %d: ",n);
    leerCadena(nom[n],20);
  return n+1;
}
void leerCadena(char cadena[],int n){//Funcion genera capaz de leer muchos caracteres.
    int len;
    getchar();
    fgets(cadena,n,stdin);
    len = strlen(cadena)-1;//retorna el tamaño o longitud de cadena y elimina el salto de linea.
    cadena[len]='\n';// Sustituya el salto de linea por el caracter nulo y por ende se BORRA.

}
